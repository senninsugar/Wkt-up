<!DOCTYPE html>
<html lang="ja" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>統合学習支援ポータル</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>
  <link rel="icon" href="https://upload.wikimedia.org/wikipedia/commons/1/19/Google_Classroom_Logo.svg" />
  <style>
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes gradientBG {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .animate-fadeIn {
      animation: fadeIn 0.8s ease-out forwards;
    }
    .bg-animated {
      background: linear-gradient(-45deg, #1e293b, #0f172a, #1e1b4b, #111827);
      background-size: 400% 400%;
      animation: gradientBG 15s ease infinite;
    }
    .glass-card {
      background: rgba(30, 41, 59, 0.7);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
  </style>
</head>
<body class="bg-animated text-gray-100 min-h-screen overflow-hidden flex items-center justify-center">
  
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-blue-600/20 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-indigo-600/20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 max-w-5xl w-full mx-4 md:mx-8 min-h-[600px] shadow-2xl rounded-3xl overflow-hidden border border-white/5">
    
    <div class="hidden md:flex flex-col justify-center items-center bg-white/5 backdrop-blur-md p-12 border-r border-white/10">
      <div class="space-y-8">
        <div class="inline-block px-4 py-1 rounded-full bg-blue-500/20 border border-blue-500/30 text-blue-300 text-xs font-bold uppercase tracking-widest">
          Information
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-white">お知らせ</h2>
        <ul class="space-y-4 text-gray-300">
          <li class="flex items-start space-x-3">
            <span class="text-blue-400 mt-1">✦</span>
            <span class="text-sm leading-relaxed">定期メンテナンスは毎週火曜0:00〜4:00に行われます。</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-blue-400 mt-1">✦</span>
            <span class="text-sm leading-relaxed">パスワード共有は厳禁です。</span>
          </li>
          <li class="flex items-start space-x-3">
            <span class="text-blue-400 mt-1">✦</span>
            <span class="text-sm leading-relaxed">不正アクセスが検出された場合、記録されます。</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col justify-center p-8 md:p-12 bg-gray-900/40 backdrop-blur-sm animate-fadeIn">
      <div id="loginCard" class="transition-all duration-500 ease-in-out">
        <div class="flex flex-col items-center mb-10">
          <div class="p-3 bg-white/10 rounded-2xl mb-4 ring-1 ring-white/20">
            <img src="https://upload.wikimedia.org/wikipedia/commons/1/19/Google_Classroom_Logo.svg" alt="Logo" class="w-12 h-12">
          </div>
          <h1 class="text-2xl font-bold tracking-tight text-white text-center" id="titleText">統合学習支援ポータル</h1>
          <p class="text-gray-400 text-sm mt-2">アカウント情報を入力してください</p>
        </div>

        <form id="loginForm" class="space-y-6">
          <div class="space-y-2">
            <label for="password" class="block text-xs font-semibold uppercase tracking-wider text-gray-400 ml-1" id="labelText">認証コード</label>
            <input
              type="password"
              id="password"
              placeholder="ここに入力..."
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent focus:outline-none transition-all duration-200 placeholder:text-gray-600 text-white"
            />
          </div>
          
          <button
            type="submit"
            class="w-full bg-blue-600 hover:bg-blue-500 active:scale-[0.98] text-white py-3 rounded-xl font-bold shadow-lg shadow-blue-900/20 transition-all duration-200"
            id="submitButton"
          >
              サインイン
          </button>
        </form>

        <div class="mt-6 text-center">
          <button onclick="guestLogin()" class="text-blue-400 hover:text-blue-300 text-sm font-medium transition-colors duration-200 decoration-dotted underline underline-offset-4">ゲストとしてログイン</button>
        </div>

        <div id="loadingSpinner" class="hidden mt-6 flex flex-col items-center space-y-3">
          <div class="w-8 h-8 border-3 border-blue-400/30 border-t-blue-500 rounded-full animate-spin"></div>
          <span class="text-xs text-gray-400 animate-pulse">認証中...</span>
        </div>

        <div id="errorMsg" class="mt-4 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm text-center hidden">
          コードが違います。再確認してください。
        </div>

        <div id="touchIdFake" class="hidden mt-8 p-4 bg-blue-500/5 rounded-2xl border border-blue-500/10 text-center text-sm text-blue-300 space-y-1">
          <p>システム確認中...</p>
          <p class="opacity-70">アカウントを確認しています...</p>
        </div>

        <div class="mt-12 flex flex-col items-center space-y-4">
          <button onclick="switchLang()" class="px-4 py-1.5 rounded-full bg-white/5 hover:bg-white/10 text-gray-400 text-xs transition-all">
            Switch to English
          </button>
          <p class="text-[10px] text-gray-500 uppercase tracking-widest">© 2025 waitkame</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    const correctPassword = "wakame";

    const lang = {
      ja: {
        title: "統合学習支援ポータル",
        label: "認証コード",
        button: "サインイン",
        error: "コードが違います。再確認してください。"
      },
      en: {
        title: "Integrated Learning Portal",
        label: "Access Code",
        button: "Sign In",
        error: "Invalid code. Please try again."
      }
    };

    let currentLang = 'ja';

    function switchLang() {
      currentLang = currentLang === 'ja' ? 'en' : 'ja';
      document.getElementById('titleText').textContent = lang[currentLang].title;
      document.getElementById('labelText').textContent = lang[currentLang].label;
      document.getElementById('submitButton').textContent = lang[currentLang].button;
      document.getElementById('errorMsg').textContent = lang[currentLang].error;
    }

    document.getElementById("loginForm").addEventListener("submit", function (e) {
      e.preventDefault();
      const enteredPassword = document.getElementById("password").value;
      const spinner = document.getElementById("loadingSpinner");
      const error = document.getElementById("errorMsg");
      const touchId = document.getElementById("touchIdFake");

      spinner.classList.remove("hidden");
      error.classList.add("hidden");
      touchId.classList.add("hidden");

      setTimeout(() => {
        if (enteredPassword === correctPassword) {
          touchId.classList.remove("hidden");
          spinner.classList.add("hidden");
          setTimeout(() => {
            document.cookie = "loginok=ok; path=/; max-age=31536000";
            document.getElementById("loginCard").classList.add("opacity-0");
            setTimeout(() => {
              window.location.href = "/wkt";
            }, 500);
          }, 1500);
        } else {
          spinner.classList.add("hidden");
          error.classList.remove("hidden");
        }
      }, 1200);
    });

    function guestLogin() {
      const steps = [
        "仙人tubeを知ってるか確認中",
        "ネットワーク環境をスキャン中...",
        "一時セッションを生成中...",
      ];
      let i = 0;
      const error = document.getElementById("errorMsg");
      error.classList.add("hidden");
      const spinner = document.getElementById("loadingSpinner");
      const touchId = document.getElementById("touchIdFake");
      const loginCard = document.getElementById("loginCard");

      spinner.classList.remove("hidden");
      touchId.classList.remove("hidden");

      function nextStep() {
        if (i < steps.length) {
          touchId.innerHTML = `<p>${steps[i]}</p>`;
          i++;
          setTimeout(nextStep, 1000);
        } else {
          touchId.innerHTML = "<p>ログイン処理中...</p>";
          setTimeout(() => {
            document.cookie = "loginok=ok; path=/; max-age=31536000";
            loginCard.classList.add("opacity-0");
            setTimeout(() => {
              window.location.href = "/wkt";
            }, 500);
          }, 1000);
        }
      }
      nextStep();
    }
  </script>
</body>
</html>
